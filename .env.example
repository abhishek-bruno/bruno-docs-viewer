# Copy to .env.local to override the docs renderer source in local dev.
# By default the renderer loads from the CDN (staging.cdn.usebruno.com/docs).
#
# To use a locally-built oc-docs renderer instead:
#   1. In the opencollection repo:  cd packages/oc-docs && npm run build:standalone
#   2. Serve the output:            npx serve packages/oc-docs/dist-standalone -l 5555
#   3. Uncomment the two lines below, then restart `npm run dev`.
#
# VITE_RENDERER_JS_URL=http://localhost:5555/api-docs.js
# VITE_RENDERER_CSS_URL=http://localhost:5555/api-docs.css
